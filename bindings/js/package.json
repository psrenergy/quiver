{
  "name": "quiverdb",
  "version": "0.7.0",
  "description": "SQLite wrapper binding for Quiver via koffi FFI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "license": "MIT",
  "keywords": [
    "sqlite",
    "database",
    "ffi",
    "node",
    "deno",
    "quiver"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "koffi": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  }
}
