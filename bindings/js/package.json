{
  "name": "quiverdb",
  "version": "0.5.0",
  "description": "Bun-native SQLite wrapper binding for Quiver via bun:ffi",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
